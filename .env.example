# -----------------------------------------------------------------------------
# PoliBrawl Environment Variables Template (.env.example)
# Copy this file to .env.local and fill in your actual credentials.
# DO NOT commit .env.local with real credentials to source control.
# -----------------------------------------------------------------------------

# Supabase API Configuration
# Get these from Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key (Keep secret! Do not share or expose to client-side bundles)
# Get this from Supabase Project Settings > API (service_role)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database Connection String
# PostgreSQL connection string for Prisma or direct PG client queries.
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# Optional secondary database configuration keys (if needed by seeding scripts)
# POSTGRES_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres
# SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# Application URLs
# The public/base URL of the Next.js application
EDITORIAL_SITE_URL=http://localhost:3000

# Editorial Management & Access
# Comma-separated list of email addresses allowed to bypass admin registration checks in development
DEV_BOOTSTRAP_OWNER_EMAILS=admin@example.com,editor@example.com
